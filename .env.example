# StudyHub configuration.
#
# In development/test every variable is optional: missing values fall back to
# the compose.dev.yml stack defaults shown below, so a fresh checkout runs with
# no .env at all. In production (APP_ENV=production) every variable is
# required; the app refuses to start otherwise.
#
# Deno does not auto-load .env files. Either export these in your shell or run
# tasks with `deno run --env-file ...` where needed.

# development | test | production
APP_ENV=development

# Public base URL of the app (used in links sent to participants).
APP_URL=http://localhost:8000

# Postgres connection string.
DATABASE_URL=postgres://studyhub:studyhub@localhost:5432/studyhub

# Object storage (MinIO locally; AWS S3 ap-southeast-1 in production).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_FILES=studyhub-files
S3_BUCKET_BACKUPS=studyhub-backups

# Outgoing email (Mailpit locally — UI at http://localhost:8025;
# SES SMTP ap-southeast-1 in production).
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM="StudyHub <studyhub@localhost>"
# SMTP auth — leave empty for Mailpit; set SES SMTP credentials in
# production (a username triggers STARTTLS + AUTH LOGIN).
SMTP_USERNAME=
SMTP_PASSWORD=
# Shared secret for the SES bounce webhook (?token=...). Empty = no check.
SES_WEBHOOK_TOKEN=

# App-layer PII encryption (AES-256-GCM). Comma-separated
# <version>:<base64 32-byte key> pairs; the highest version encrypts, all
# versions decrypt. Rotate by appending a new version. Generate a key with:
#   openssl rand -base64 32
# The dev fallback key is public — NEVER use it outside development.
PII_ENCRYPTION_KEYS=1:c3R1ZHlodWItZGV2LW9ubHktYWVzLWtleS0zMi1ieSE=

# HMAC secret for participant magic links (min 32 chars).
MAGIC_LINK_SECRET=studyhub-dev-only-magic-link-secret-do-not-deploy

# HMAC key for the blind index over encrypted PII (contact-channel dedup
# and lookup; min 32 chars). NEVER rotate without re-indexing.
PII_INDEX_SECRET=studyhub-dev-only-pii-index-secret-do-not-deploy

# Cloudflare Turnstile (public screener/consent pages). Optional: empty
# outside production uses a local stub; empty IN production fails closed
# (public forms reject all submissions until keys are set).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# In-process job runner (message delivery cron; Deno.cron, needs
# --unstable-cron). Off by default in dev.
JOBS_ENABLED=false

# Nightly pg_dump job (Deno.cron; needs --unstable-cron, included in the
# start task). Defaults shown; optional in every environment.
BACKUP_CRON_ENABLED=false
BACKUP_CRON="0 18 * * *"
